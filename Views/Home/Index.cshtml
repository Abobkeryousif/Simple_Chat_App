<div class="container pt-3">
    <div class="row">
        <div class="col-md-6">
            <label for="txtUser">Your Name:</label>
            <input type="text" id="txtUser" class="form-control mb-2"/>

            <label for="txtMessage">Your Message:</label>
            <textarea class="form-control mb-2" rows="5" id="txtMessage"></textarea>

            <button type="button" class="btn btn-info w-100" id="btnSend">
                Send Message
            </button>
        </div>

        <div class="col-md-6">
            <h3>Message List:</h3>
            <ul id="list" class="list-group"></ul>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/lib/signalr/dist/browser/signalr.js"></script>
<script src="~/js/site.js"></script>
